# --- Runtime ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
PUBLIC_BASE_URL=http://localhost:3001

# --- Database ---
DATABASE_URL=postgres://devpinger:devpinger@localhost:5432/devpinger
DATABASE_POOL_SIZE=10

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Telegram bot ---
# Create via @BotFather, paste token here.
TELEGRAM_BOT_TOKEN=
# Username without leading @ (e.g. devpinger_bot).
TELEGRAM_BOT_USERNAME=devpinger_bot
# 16+ chars; used as Telegram webhook secret_token in production.
TELEGRAM_WEBHOOK_SECRET=

# --- Encryption (AES-256-GCM for OAuth tokens at rest) ---
# 64 hex chars (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- GitHub OAuth App ---
# Register at https://github.com/settings/developers
# Callback URL: $PUBLIC_BASE_URL/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3001/oauth/github/callback
# 32+ char random seed; used to derive per-installation webhook HMAC secrets
# (each subscription gets its own secret, derived from this seed + scope).
GITHUB_WEBHOOK_SECRET_SEED=

# --- Atlassian OAuth (Jira Cloud 3LO) ---
# Create at https://developer.atlassian.com → My Apps → OAuth 2.0 (3LO)
# Scopes: read:jira-user, read:jira-work, write:jira-work, offline_access
# Callback URL: $PUBLIC_BASE_URL/oauth/jira/callback
JIRA_OAUTH_CLIENT_ID=
JIRA_OAUTH_CLIENT_SECRET=
JIRA_OAUTH_REDIRECT_URI=http://localhost:3001/oauth/jira/callback

# --- Admin (optional) ---
# Telegram ID of the operator. Gates admin-only bot commands
# such as /notify_self. Leave empty to disable admin commands.
ADMIN_TELEGRAM_ID=

# --- Application error tracking (optional) ---
# Leave empty in development.
SENTRY_DSN=

# --- Preorder / Stripe ---
# Stripe webhook signing secret. Find it in Stripe Dashboard → Developers → Webhooks
# → your endpoint → "Reveal" under Signing secret. Starts with "whsec_".
# Leave empty to disable the /v1/stripe/webhook endpoint (returns 503).
STRIPE_WEBHOOK_SECRET=
# Number of lifetime preorder seats. Used by /v1/landing/seats to compute the
# remaining count and the "X / N sold" badge on the landing.
PREORDER_TOTAL_SEATS=30
