# Production environment for DevPinger backend.
# Copy this file to .env.prod in the REPO ROOT (one directory up from infra/),
# then fill in the real values. Never commit .env.prod.

# --------------------- Runtime ---------------------
NODE_ENV=production
LOG_LEVEL=info
PORT=3001

# Public URL the server is reachable at (used for OAuth callbacks and
# the Telegram webhook target). HTTPS only.
PUBLIC_BASE_URL=https://api.devpinger.com

# --------------------- Database ---------------------
# Supabase pooler (transaction mode, port 6543) for runtime.
# For migrations use the direct connection URL (host db.<ref>.supabase.co:5432).
DATABASE_URL=postgresql://postgres.<project>:<password>@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_POOL_SIZE=10

# --------------------- Redis ---------------------
# Local Redis in the compose stack — keep as is.
REDIS_URL=redis://redis:6379

# --------------------- Telegram ---------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=dev_pinger_bot
TELEGRAM_WEBHOOK_SECRET=

# --------------------- Encryption ---------------------
# 32 random bytes, hex-encoded. Generate with:
#   openssl rand -hex 32
ENCRYPTION_KEY=

# --------------------- GitHub OAuth ---------------------
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://api.devpinger.com/oauth/github/callback

# --------------------- Jira OAuth ---------------------
JIRA_OAUTH_CLIENT_ID=
JIRA_OAUTH_CLIENT_SECRET=
JIRA_OAUTH_REDIRECT_URI=https://api.devpinger.com/oauth/jira/callback

# --------------------- Optional ---------------------
SENTRY_DSN=
ADMIN_TELEGRAM_ID=

# Origins allowed to call public landing endpoints from a browser.
LANDING_ALLOWED_ORIGINS=https://devpinger.com,https://www.devpinger.com,https://preorder.devpinger.com
