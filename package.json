{
	"name": "devpinger",
	"version": "0.0.0",
	"private": true,
	"description": "Unified dev-tools inbox delivered to Telegram",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"db:generate": "pnpm --filter @devpinger/db generate",
		"db:migrate": "pnpm --filter @devpinger/db migrate",
		"db:studio": "pnpm --filter @devpinger/db studio",
		"clean": "turbo run clean && rm -rf node_modules"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"turbo": "^2.3.3",
		"typescript": "^5.7.2"
	}
}
