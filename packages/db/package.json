{
	"name": "@devpinger/db",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./schema": "./src/schema/index.ts"
	},
	"scripts": {
		"build": "tsc",
		"generate": "tsc && drizzle-kit generate",
		"migrate": "tsx src/migrate.ts",
		"push": "drizzle-kit push",
		"studio": "drizzle-kit studio",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist .turbo *.tsbuildinfo"
	},
	"dependencies": {
		"@devpinger/core": "workspace:*",
		"drizzle-orm": "^0.38.3",
		"postgres": "^3.4.5"
	},
	"peerDependencies": {
		"dotenv": "*"
	},
	"devDependencies": {
		"@devpinger/tsconfig": "workspace:*",
		"@types/node": "^22.10.5",
		"dotenv": "^16.4.7",
		"drizzle-kit": "^0.30.1",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vitest": "^2.1.9"
	}
}
