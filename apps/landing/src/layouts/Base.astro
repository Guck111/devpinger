---
interface Props {
  title: string;
  description?: string;
  path: string;
  ru?: Record<string, string>;
  noindex?: boolean;
}

const { title, description, path, ru = {}, noindex = false } = Astro.props;
const canonical = `https://preorder.devpinger.com${path}`;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>{title}</title>
{description && <meta name="description" content={description} />}
{noindex && <meta name="robots" content="noindex, follow" />}
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content="https://preorder.devpinger.com/og-image.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<link rel="canonical" href={canonical} />
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#0c0d0e" media="(prefers-color-scheme: dark)" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style is:global>
  :root {
    --bg: #ffffff;
    --bg-soft: #fafafa;
    --bg-elev: #ffffff;
    --fg: #0c0d0e;
    --fg-muted: #5b5f66;
    --fg-faint: #8e9197;
    --border: #ececec;
    --border-strong: #d9d9d9;
    --accent: #229ED9;
    --accent-fg: #ffffff;
    --accent-soft: #e9f5fc;
    --good: #1a9f5d;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0c0d0e;
      --bg-soft: #131416;
      --bg-elev: #131416;
      --fg: #f5f5f4;
      --fg-muted: #a1a3a8;
      --fg-faint: #6b6e74;
      --border: #1f2125;
      --border-strong: #2a2c31;
      --accent: #3ab1e6;
      --accent-fg: #06121a;
      --accent-soft: #122733;
      --good: #4ade80;
    }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    background: var(--bg);
    color: var(--fg);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    font-size: 16px;
  }
  .mono { font-family: 'Geist Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
  a { color: inherit; }
  a.link {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 35%, transparent);
  }
  a.link:hover { border-bottom-color: var(--accent); }
  .wrap { max-width: 760px; margin: 0 auto; padding: 0 28px; }

  .nav { padding: 22px 0; border-bottom: 1px solid var(--border); }
  .nav-row { display: flex; align-items: center; justify-content: space-between; gap: 16px; max-width: 1120px; margin: 0 auto; padding: 0 28px; }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 600; font-size: 16px; letter-spacing: -0.01em; text-decoration: none; color: var(--fg); }
  .brand-mark { width: 22px; height: 22px; background: var(--accent); border-radius: 6px; display: inline-flex; align-items: center; justify-content: center; color: var(--accent-fg); }
  @keyframes ping-arc {
    0%   { opacity: 0; transform: scale(.6); }
    20%  { opacity: 1; }
    100% { opacity: 0; transform: scale(1.6); }
  }
  .anim-ping .arc-anim { transform-origin: 6px 16px; animation: ping-arc 2.4s ease-out infinite; }
  .anim-ping .arc-anim.delay-1 { animation-delay: .8s; }
  @media (prefers-reduced-motion: reduce) {
    .anim-ping .arc-anim { animation: none; }
  }
  .nav-right { display: flex; align-items: center; gap: 16px; }
  .nav-back { color: var(--fg-muted); text-decoration: none; font-size: 14px; }
  .nav-back:hover { color: var(--fg); }

  .lang-switch {
    display: inline-flex;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    padding: 2px;
    background: var(--bg-elev);
  }
  .lang-switch button {
    font: inherit; font-size: 11px; font-weight: 500;
    padding: 5px 9px;
    background: transparent; color: var(--fg-muted);
    border: 0; border-radius: 6px;
    cursor: pointer;
    letter-spacing: 0.06em;
    font-family: 'Geist Mono', ui-monospace, monospace;
  }
  .lang-switch button[aria-pressed="true"] {
    background: var(--fg);
    color: var(--bg);
  }
  .lang-switch button:hover:not([aria-pressed="true"]) { color: var(--fg); }

  main.page { padding: 56px 0 80px; }
  main.page h1 { font-size: clamp(28px, 5vw, 44px); font-weight: 600; letter-spacing: -0.03em; line-height: 1.05; margin: 0 0 24px; }
  main.page h2 { font-size: 20px; font-weight: 600; margin: 36px 0 12px; }
  main.page p { color: var(--fg); font-size: 16px; line-height: 1.65; margin: 0 0 16px; max-width: 64ch; }
  main.page ul, main.page ol { padding-left: 22px; margin: 0 0 16px; max-width: 64ch; }
  main.page li { margin-bottom: 8px; line-height: 1.6; }
  main.page .muted { color: var(--fg-muted); font-size: 14.5px; }
  main.page .lede { font-size: 18px; color: var(--fg-muted); margin-bottom: 32px; max-width: 60ch; }
  main.page code { font-family: 'Geist Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 0.9em; background: var(--bg-soft); padding: 1px 6px; border-radius: 4px; }

  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    font: inherit; font-weight: 500; font-size: 15px;
    padding: 12px 18px; border-radius: 10px;
    border: 1px solid transparent; cursor: pointer; text-decoration: none;
  }
  .btn-primary { background: var(--accent); color: var(--accent-fg); }
  .btn-primary:hover { background: color-mix(in oklab, var(--accent) 90%, black); }
  .btn-lg { padding: 14px 22px; font-size: 16px; border-radius: 12px; }

  footer.foot { padding: 36px 0 56px; border-top: 1px solid var(--border); color: var(--fg-muted); font-size: 13.5px; }
  .foot-row { display: flex; flex-wrap: wrap; gap: 20px; align-items: center; justify-content: space-between; max-width: 1120px; margin: 0 auto; padding: 0 28px; }
  .foot-links { display: flex; flex-wrap: wrap; gap: 18px; }
  .foot-links a { color: var(--fg-muted); text-decoration: none; }
  .foot-links a:hover { color: var(--fg); }
</style>
</head>
<body>

<header class="nav">
  <div class="nav-row">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true">
        <svg class="anim-ping" width="14" height="14" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="6" cy="16" r="3" fill="currentColor"/>
          <path class="arc-anim" d="M11 11.5C13.5 14 13.5 18 11 20.5" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          <path class="arc-anim delay-1" d="M16 7.5C20.5 11 20.5 21 16 24.5" stroke="currentColor" stroke-width="3" stroke-linecap="round" opacity=".55"/>
        </svg>
      </span>
      DevPinger
    </a>
    <div class="nav-right">
      <a class="nav-back" href="/" data-i18n="nav.back">← Back to homepage</a>
      <div class="lang-switch" role="group" aria-label="Language">
        <button type="button" data-lang="en" aria-pressed="true">EN</button>
        <button type="button" data-lang="ru" aria-pressed="false">RU</button>
      </div>
    </div>
  </div>
</header>

<main class="page">
  <div class="wrap">
    <slot />
  </div>
</main>

<footer class="foot">
  <div class="foot-row">
    <div>© 2026 DevPinger</div>
    <div class="foot-links">
      <a href="/privacy" data-i18n="foot.privacy">Privacy</a>
      <a href="/terms" data-i18n="foot.terms">Terms (preorder)</a>
      <a href="https://t.me/dev_pinger_bot" target="_blank" rel="noopener noreferrer" data-i18n="foot.status">Status</a>
      <a href="https://github.com/Guck111/devpinger" target="_blank" rel="noopener noreferrer" data-i18n="foot.source">Source</a>
    </div>
  </div>
</footer>

<script is:inline type="application/json" id="i18n-ru-data" set:html={JSON.stringify({
  'nav.back': '← На главную',
  'foot.privacy': 'Политика',
  'foot.terms': 'Условия (предзаказ)',
  'foot.status': 'Статус',
  'foot.source': 'Исходники',
  ...ru,
})}></script>

<script is:inline define:vars={{ enTitle: title, ruTitle: ru['meta.title'] ?? title }}>
  const ruDict = JSON.parse(document.getElementById('i18n-ru-data').textContent || '{}');

  const enSnap = new Map();
  document.querySelectorAll('[data-i18n]').forEach((el) => {
    enSnap.set(el.getAttribute('data-i18n'), el.textContent);
  });

  function applyLang(lang) {
    document.documentElement.setAttribute('lang', lang);
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (lang === 'ru' && key in ruDict) el.textContent = ruDict[key];
      else if (enSnap.has(key)) el.textContent = enSnap.get(key);
    });
    document.querySelectorAll('[data-lang-show]').forEach((el) => {
      el.hidden = el.getAttribute('data-lang-show') !== lang;
    });
    document.title = lang === 'ru' ? ruTitle : enTitle;
    document.querySelectorAll('.lang-switch button').forEach((b) => {
      b.setAttribute('aria-pressed', b.getAttribute('data-lang') === lang ? 'true' : 'false');
    });
    try { localStorage.setItem('lang', lang); } catch (_e) {}
  }

  document.querySelectorAll('.lang-switch button').forEach((b) => {
    b.addEventListener('click', () => applyLang(b.getAttribute('data-lang')));
  });

  let initLang = 'en';
  try {
    const stored = localStorage.getItem('lang');
    if (stored === 'ru' || stored === 'en') initLang = stored;
    else if ((navigator.language || '').toLowerCase().startsWith('ru')) initLang = 'ru';
  } catch (_e) {}
  applyLang(initLang);
</script>

</body>
</html>
