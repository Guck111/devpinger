---
const API_BASE = import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:3001";
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>DevPinger — Don't miss a failed payment.</title>
<meta name="description" content="Stripe failures, Sentry errors, GitHub PRs — all in one Telegram chat. Built for solo SaaS founders who want to know before their customers do." />
<meta property="og:title" content="DevPinger — Don't miss a failed payment." />
<meta property="og:description" content="Stripe failures, Sentry errors, GitHub PRs — all in one Telegram chat." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://devpinger.com/" />
<meta property="og:image" content="https://devpinger.com/og-image.svg" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="DevPinger — Don't miss a failed payment." />
<meta name="twitter:description" content="Stripe failures, Sentry errors, GitHub PRs — all in one Telegram chat." />
<meta name="twitter:image" content="https://devpinger.com/og-image.svg" />
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#0c0d0e" media="(prefers-color-scheme: dark)" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />

<!-- TODO: подключить Plausible или Cloudflare Web Analytics. Скрипт-тег вставить здесь, см. brief. -->

<style is:global>
  :root {
    --bg: #ffffff;
    --bg-soft: #fafafa;
    --bg-elev: #ffffff;
    --fg: #0c0d0e;
    --fg-muted: #5b5f66;
    --fg-faint: #8e9197;
    --border: #ececec;
    --border-strong: #d9d9d9;
    --accent: #229ED9;          /* Telegram blue */
    --accent-fg: #ffffff;
    --accent-soft: #e9f5fc;
    --good: #1a9f5d;
    --warn: #c47d00;
    --bad:  #b3261e;

    /* Telegram bubble */
    --tg-bg: #ffffff;
    --tg-border: #ececec;
    --tg-meta: #8e9197;
    --tg-text: #0c0d0e;
    --tg-btn-bg: #f1f1f1;
    --tg-btn-fg: #0c0d0e;
    --tg-name: #229ED9;
    --tg-mono-bg: #f4f4f5;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0c0d0e;
      --bg-soft: #131416;
      --bg-elev: #131416;
      --fg: #f5f5f4;
      --fg-muted: #a1a3a8;
      --fg-faint: #6b6e74;
      --border: #1f2125;
      --border-strong: #2a2c31;
      --accent: #3ab1e6;
      --accent-fg: #06121a;
      --accent-soft: #122733;
      --good: #4ade80;
      --warn: #f0b95a;
      --bad:  #f87171;

      --tg-bg: #1c1d20;
      --tg-border: #24262a;
      --tg-meta: #8a8d93;
      --tg-text: #f1f1ef;
      --tg-btn-bg: #2a2c31;
      --tg-btn-fg: #e8e9eb;
      --tg-name: #6ec4ee;
      --tg-mono-bg: #131416;
    }
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-feature-settings: "ss01", "cv11";
    background: var(--bg);
    color: var(--fg);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    font-size: 16px;
  }
  ::selection { background: var(--accent); color: var(--accent-fg); }

  .mono { font-family: 'Geist Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }

  a { color: inherit; }
  a.link {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 35%, transparent);
    transition: border-color .15s ease;
  }
  a.link:hover { border-bottom-color: var(--accent); }

  .wrap {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 28px;
  }

  /* ---------- Nav ---------- */
  .nav {
    padding: 22px 0;
    position: sticky;
    top: 0;
    background: color-mix(in oklab, var(--bg) 85%, transparent);
    backdrop-filter: saturate(180%) blur(8px);
    -webkit-backdrop-filter: saturate(180%) blur(8px);
    z-index: 50;
    border-bottom: 1px solid transparent;
    transition: border-color .2s ease;
  }
  .nav.scrolled { border-bottom-color: var(--border); }
  .nav-row {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
  }
  .brand {
    display: inline-flex; align-items: center; gap: 10px;
    font-weight: 600; font-size: 16px; letter-spacing: -0.01em;
    text-decoration: none; color: var(--fg);
  }
  .brand-mark {
    width: 22px; height: 22px;
    background: var(--accent);
    border-radius: 6px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--accent-fg);
  }
  .nav-links {
    display: flex; align-items: center; gap: 22px;
  }
  .nav-links a {
    text-decoration: none; color: var(--fg-muted); font-size: 14px;
    transition: color .15s ease;
  }
  .nav-links a:hover { color: var(--fg); }
  .nav-links .ghost {
    display: inline-flex; align-items: center; gap: 7px;
    border: 1px solid var(--border-strong); padding: 7px 11px; border-radius: 8px;
    color: var(--fg);
  }
  .nav-links .ghost:hover { background: var(--bg-soft); }
  @media (max-width: 640px) {
    .nav-links a:not(.ghost) { display: none; }
  }

  /* Language switcher */
  .lang-switch {
    display: inline-flex;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    padding: 2px;
    background: var(--bg-elev);
  }
  .lang-switch button {
    font: inherit; font-size: 11px; font-weight: 500;
    padding: 5px 9px;
    background: transparent; color: var(--fg-muted);
    border: 0; border-radius: 6px;
    cursor: pointer;
    letter-spacing: 0.06em;
    font-family: 'Geist Mono', ui-monospace, monospace;
    transition: background .12s ease, color .12s ease;
  }
  .lang-switch button[aria-pressed="true"] {
    background: var(--fg);
    color: var(--bg);
  }
  .lang-switch button:hover:not([aria-pressed="true"]) { color: var(--fg); }

  /* ---------- Buttons ---------- */
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    font: inherit; font-weight: 500; font-size: 15px;
    padding: 12px 18px; border-radius: 10px;
    border: 1px solid transparent; cursor: pointer; text-decoration: none;
    transition: transform .08s ease, background .15s ease, border-color .15s ease, color .15s ease;
    white-space: nowrap;
  }
  .btn:active { transform: translateY(1px); }
  .btn-primary {
    background: var(--accent); color: var(--accent-fg);
    box-shadow: 0 1px 0 rgba(0,0,0,.04), 0 1px 3px rgba(34,158,217,.25);
  }
  .btn-primary:hover { background: color-mix(in oklab, var(--accent) 90%, black); }
  .btn-ghost {
    background: transparent; color: var(--fg);
    border-color: var(--border-strong);
  }
  .btn-ghost:hover { background: var(--bg-soft); }
  .btn-lg { padding: 14px 22px; font-size: 16px; border-radius: 12px; }

  /* ---------- Section scaffolding ---------- */
  section { padding: 96px 0; border-top: 1px solid var(--border); }
  section:first-of-type { border-top: 0; padding-top: 60px; }
  @media (max-width: 640px) { section { padding: 64px 0; } }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--fg-muted);
  }
  .eyebrow::before {
    content: ""; width: 6px; height: 6px; border-radius: 999px; background: var(--accent);
  }
  h1, h2, h3 { letter-spacing: -0.025em; margin: 0; text-wrap: balance; }
  h2 { font-size: clamp(28px, 4vw, 40px); font-weight: 600; line-height: 1.1; }
  h3 { font-size: 18px; font-weight: 600; }
  p { text-wrap: pretty; }
  .lede { color: var(--fg-muted); font-size: 17px; max-width: 60ch; }

  /* ---------- Hero ---------- */
  .hero {
    padding: 88px 0 96px;
    border-top: 0;
  }
  .hero h1 {
    font-size: clamp(40px, 7.2vw, 84px);
    line-height: 0.98;
    font-weight: 600;
    letter-spacing: -0.035em;
    max-width: 14ch;
  }
  .hero h1 .accent { color: var(--accent); }
  .hero-sub {
    margin-top: 28px;
    font-size: clamp(17px, 1.6vw, 19px);
    line-height: 1.5;
    color: var(--fg-muted);
    max-width: 56ch;
  }
  .hero-cta {
    margin-top: 36px;
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  }
  .hero-trust {
    margin-top: 22px;
    display: flex; flex-wrap: wrap; gap: 14px 18px;
    font-size: 13.5px; color: var(--fg-muted);
  }
  .hero-trust .dot { color: var(--fg-faint); }
  .hero-trust .check { color: var(--good); }
  .hero-secondary {
    margin-top: 28px;
    font-size: 14.5px;
    color: var(--fg-muted);
  }
  .hero-secondary a { color: var(--fg); text-decoration: none; border-bottom: 1px solid var(--border-strong); padding-bottom: 1px; }
  .hero-secondary a:hover { border-bottom-color: var(--fg); }

  /* Decorative monospace tag in hero corner */
  .hero-meta {
    position: absolute; right: 28px; top: 88px;
    display: flex; flex-direction: column; align-items: flex-end; gap: 4px;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 11px; color: var(--fg-faint);
    pointer-events: none;
  }
  .hero-meta b { color: var(--fg-muted); font-weight: 500; }
  .hero-wrap { position: relative; }
  @media (max-width: 900px) { .hero-meta { display: none; } }

  /* ---------- Section 2: Telegram mocks ---------- */
  .section-head {
    display: flex; flex-direction: column; gap: 10px; max-width: 60ch; margin-bottom: 48px;
  }

  .mock-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 980px) { .mock-grid { grid-template-columns: 1fr; gap: 18px; max-width: 480px; margin: 0 auto;} }

  .tg {
    background: var(--tg-bg);
    border: 1px solid var(--tg-border);
    border-radius: 16px;
    padding: 18px 18px 16px;
    box-shadow: 0 1px 2px rgba(0,0,0,.03), 0 12px 32px -16px rgba(0,0,0,.08);
    font-size: 14.5px;
    color: var(--tg-text);
    display: flex; flex-direction: column; gap: 12px;
    position: relative;
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .tg:hover { transform: translateY(-2px); box-shadow: 0 1px 2px rgba(0,0,0,.03), 0 24px 48px -20px rgba(0,0,0,.12); }
  .tg-head {
    display: flex; align-items: baseline; justify-content: space-between; gap: 12px;
  }
  .tg-name {
    font-weight: 600; color: var(--tg-name); font-size: 14px;
  }
  .tg-time { color: var(--tg-meta); font-size: 12px; font-variant-numeric: tabular-nums; }
  .tg-divider { height: 1px; background: var(--tg-border); }
  .tg-title {
    font-weight: 600; font-size: 15px; display: flex; align-items: center; gap: 8px;
  }
  .tg-title .emoji { font-size: 17px; line-height: 1; }
  .tg-fields {
    display: grid; grid-template-columns: auto 1fr; gap: 4px 14px;
    font-size: 13.5px;
  }
  .tg-fields dt { color: var(--tg-meta); font-weight: 400; }
  .tg-fields dd {
    margin: 0; color: var(--tg-text);
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 13px;
    overflow-wrap: anywhere;
  }
  .tg-note { color: var(--tg-text); font-size: 13.5px; line-height: 1.45; }
  .tg-note.warn { color: var(--bad); }
  .tg-actions {
    display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px;
  }
  .tg-btn {
    background: var(--tg-btn-bg);
    color: var(--tg-btn-fg);
    border: 0;
    padding: 8px 12px;
    border-radius: 8px;
    font: inherit; font-size: 13px; font-weight: 500;
    cursor: pointer;
    flex: 1 1 auto;
    min-width: 0;
    text-align: center;
    transition: background .12s ease;
  }
  .tg-btn:hover { background: color-mix(in oklab, var(--tg-btn-bg) 80%, var(--accent) 20%); color: var(--accent); }
  .tg-btn-primary {
    background: var(--accent); color: var(--accent-fg);
  }
  .tg-btn-primary:hover { background: color-mix(in oklab, var(--accent) 88%, black); color: var(--accent-fg); }
  .tg-status {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12.5px; color: var(--tg-meta);
  }
  .tg-status .ok { color: var(--good); }

  .caption {
    margin-top: 40px;
    color: var(--fg-muted);
    font-size: 15px;
    max-width: 70ch;
  }

  /* ---------- Section 3: How it works ---------- */
  .steps {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 36px;
  }
  @media (max-width: 860px) { .steps { grid-template-columns: 1fr; gap: 36px; } }
  .step .num {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 56px; line-height: 1; font-weight: 500;
    color: var(--fg);
    display: inline-block;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--border);
    width: 100%;
    margin-bottom: 22px;
    letter-spacing: -0.04em;
  }
  .step .num span { color: var(--fg-faint); margin-left: 6px; font-size: 18px; vertical-align: top; }
  .step h3 { margin-bottom: 8px; }
  .step p { margin: 0; color: var(--fg-muted); font-size: 15px; max-width: 36ch; }

  /* ---------- Section 4: Compare table ---------- */
  .compare-wrap {
    border: 1px solid var(--border); border-radius: 14px; overflow: hidden;
    background: var(--bg-elev);
  }
  table.compare {
    width: 100%; border-collapse: collapse;
    font-size: 14.5px;
  }
  .compare th, .compare td {
    padding: 14px 18px; text-align: left;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }
  .compare thead th {
    font-weight: 500; color: var(--fg-muted); font-size: 13px;
    background: var(--bg-soft);
    letter-spacing: 0.01em;
  }
  .compare tbody tr:last-child td { border-bottom: 0; }
  .compare td:not(:first-child), .compare th:not(:first-child) { text-align: center; }
  .compare th.col-us { color: var(--accent); font-weight: 600; }
  .compare td.us { background: color-mix(in oklab, var(--accent) 4%, transparent); }
  .compare .row-label { color: var(--fg); font-weight: 500; }
  .compare .row-sub { color: var(--fg-faint); font-size: 12.5px; display: block; margin-top: 2px; font-weight: 400; }

  .mark { display: inline-flex; align-items: center; justify-content: center; }
  .mark-yes { color: var(--good); }
  .mark-no { color: var(--fg-faint); }
  .mark-partial { color: var(--warn); font-size: 13px; }
  .mark-partial .label { margin-left: 4px; color: var(--fg-muted); font-size: 12.5px; }

  @media (max-width: 720px) {
    .compare th, .compare td { padding: 12px 10px; font-size: 13.5px; }
    .compare .row-sub { display: none; }
  }

  /* ---------- Section 5: Pricing ---------- */
  .pricing {
    display: grid; grid-template-columns: 1.05fr 1fr; gap: 24px;
  }
  @media (max-width: 860px) { .pricing { grid-template-columns: 1fr; } }
  .card {
    border: 1px solid var(--border);
    background: var(--bg-elev);
    border-radius: 18px;
    padding: 32px;
    display: flex; flex-direction: column; gap: 22px;
    position: relative;
  }
  .card.featured {
    border-color: color-mix(in oklab, var(--accent) 40%, var(--border));
    box-shadow: 0 0 0 1px color-mix(in oklab, var(--accent) 30%, transparent) inset,
                0 24px 60px -28px color-mix(in oklab, var(--accent) 30%, transparent);
  }
  .card.muted { background: var(--bg-soft); }
  .card.muted h3, .card.muted .price { color: var(--fg-muted); }
  .badge {
    display: inline-flex; align-items: center; gap: 8px;
    align-self: flex-start;
    padding: 5px 10px;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 12px; font-weight: 500;
    font-family: 'Geist Mono', ui-monospace, monospace;
    letter-spacing: 0.02em;
  }
  .badge .dot { width: 6px; height: 6px; border-radius: 999px; background: var(--accent); animation: pulse 2.4s ease-in-out infinite; }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: .35; }
  }
  .price { font-size: 56px; font-weight: 600; letter-spacing: -0.035em; line-height: 1; }
  .price small { font-size: 16px; color: var(--fg-muted); font-weight: 500; margin-left: 6px; letter-spacing: 0; }
  .feature-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .feature-list li { display: flex; gap: 12px; align-items: flex-start; font-size: 14.5px; color: var(--fg); }
  .feature-list li svg { flex-shrink: 0; margin-top: 2px; color: var(--accent); }
  .card.muted .feature-list li svg { color: var(--fg-faint); }
  .card .btn { align-self: stretch; }
  .self-host {
    margin-top: 28px;
    text-align: center;
    color: var(--fg-muted);
    font-size: 14.5px;
  }

  /* ---------- Section 6: FAQ ---------- */
  .faq {
    max-width: 760px;
  }
  .faq-item {
    border-top: 1px solid var(--border);
  }
  .faq-item:last-child { border-bottom: 1px solid var(--border); }
  .faq-q {
    width: 100%;
    background: transparent;
    border: 0;
    -webkit-appearance: none;
    appearance: none;
    padding: 22px 0;
    text-align: left;
    cursor: pointer;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
    font: inherit;
    color: var(--fg);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .faq-q:hover { color: var(--accent); }
  .faq-q .chev {
    flex-shrink: 0; transition: transform .25s ease; color: var(--fg-muted);
  }
  .faq-item.open .faq-q .chev { transform: rotate(45deg); color: var(--accent); }
  .faq-a {
    overflow: hidden;
    max-height: 0;
    transition: max-height .3s ease;
  }
  .faq-a-inner {
    padding: 0 0 22px;
    color: var(--fg-muted);
    font-size: 15.5px;
    line-height: 1.6;
    max-width: 64ch;
  }

  /* ---------- Section 7: About ---------- */
  .about-grid {
    display: grid; grid-template-columns: 1fr 1.5fr; gap: 48px; align-items: start;
  }
  @media (max-width: 760px) { .about-grid { grid-template-columns: 1fr; gap: 28px; } }
  .avatar {
    width: 84px; height: 84px; border-radius: 16px;
    background: linear-gradient(135deg, color-mix(in oklab, var(--accent) 70%, white), var(--accent));
    color: var(--accent-fg);
    display: flex; align-items: center; justify-content: center;
    font-size: 32px; font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }
  .about-text p {
    margin: 0 0 16px;
    font-size: 16.5px;
    color: var(--fg);
    line-height: 1.6;
    max-width: 56ch;
  }
  .about-text .muted { color: var(--fg-muted); font-size: 14.5px; }
  .about-text .stats {
    display: flex; flex-wrap: wrap; gap: 8px;
    margin-top: 6px;
  }
  .chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 10px; border: 1px solid var(--border); border-radius: 999px;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 12px; color: var(--fg-muted);
  }
  .chip .v { color: var(--fg); }
  .about-links {
    margin-top: 24px;
    display: flex; gap: 18px; flex-wrap: wrap;
  }
  .about-links a {
    color: var(--fg); text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 14.5px;
    border-bottom: 1px solid var(--border-strong);
    padding-bottom: 2px;
    transition: border-color .15s ease, color .15s ease;
  }
  .about-links a:hover { color: var(--accent); border-bottom-color: var(--accent); }

  /* ---------- Footer ---------- */
  footer.foot {
    padding: 48px 0 64px;
    border-top: 1px solid var(--border);
    color: var(--fg-muted);
    font-size: 13.5px;
  }
  .foot-row {
    display: flex; flex-wrap: wrap; gap: 20px; align-items: center; justify-content: space-between;
  }
  .foot-links { display: flex; flex-wrap: wrap; gap: 18px; }
  .foot-links a { color: var(--fg-muted); text-decoration: none; }
  .foot-links a:hover { color: var(--fg); }

  /* Reveal animation on load */
  .reveal { opacity: 0; transform: translateY(8px); animation: reveal .7s cubic-bezier(.2,.7,.2,1) forwards; }
  .reveal.d1 { animation-delay: .05s; }
  .reveal.d2 { animation-delay: .15s; }
