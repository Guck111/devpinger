<script is:inline>
  // Updates form — POST to /v1/landing/subscribe (real backend)
  const updatesForm = document.getElementById('updates-form');
  if (updatesForm) {
    updatesForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = updatesForm.querySelector('button');
      const input = updatesForm.querySelector('input[name="email"]');
      const hp = updatesForm.querySelector('input[name="hp"]');
      const api = updatesForm.getAttribute('data-api');
      if (!btn || !input || !api) return;

      const isRu = document.documentElement.lang === 'ru';
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = isRu ? 'Отправляем…' : 'Sending…';

      try {
        const res = await fetch(api, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: input.value,
            source: 'landing-updates',
            hp: hp ? hp.value : undefined,
          }),
        });
        if (res.ok) {
          input.value = '';
          btn.textContent = isRu
            ? 'Спасибо — увидимся через 2 недели.'
            : 'Thanks — see you in 2 weeks.';
        } else {
          btn.disabled = false;
          btn.textContent = isRu ? 'Не вышло, попробуй ещё' : 'Failed, try again';
          setTimeout(() => { btn.textContent = original; }, 3000);
        }
      } catch (_err) {
        btn.disabled = false;
        btn.textContent = isRu ? 'Сеть недоступна' : 'Network error';
        setTimeout(() => { btn.textContent = original; }, 3000);
      }
    });
  }

