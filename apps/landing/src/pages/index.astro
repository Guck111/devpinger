  document.querySelectorAll('[data-i18n]').forEach(el => {
    enSnap.set(el.getAttribute('data-i18n'), el.innerHTML);
  });
  const enPh = new Map();
  document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
    enPh.set(el.getAttribute('data-i18n-placeholder'), el.placeholder);
  });

  function applyLang(lang) {
    document.documentElement.setAttribute('lang', lang);
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (lang === 'ru' && key in RU) el.innerHTML = RU[key];
      else if (enSnap.has(key)) el.innerHTML = enSnap.get(key);
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (lang === 'ru' && key in RU) el.placeholder = RU[key];
      else if (enPh.has(key)) el.placeholder = enPh.get(key);
    });
    document.title = (lang === 'ru' && RU['meta.title']) ? RU['meta.title'] : EN_META.title;
    const md = document.querySelector('meta[name="description"]');
    if (md) md.setAttribute('content', (lang === 'ru' && RU['meta.desc']) ? RU['meta.desc'] : EN_META.desc);
    document.querySelectorAll('.lang-switch button').forEach(b => {
      b.setAttribute('aria-pressed', b.getAttribute('data-lang') === lang ? 'true' : 'false');
    });
    // Re-measure any open FAQ items, content height may have changed
    document.querySelectorAll('.faq-item.open .faq-a').forEach(a => {
      requestAnimationFrame(() => { a.style.maxHeight = a.scrollHeight + 'px'; });
    });
    try { localStorage.setItem('lang', lang); } catch(e) {}
  }

  document.querySelectorAll('.lang-switch button').forEach(b => {
    b.addEventListener('click', () => applyLang(b.getAttribute('data-lang')));
  });

  let initLang = 'en';
  try {
    const stored = localStorage.getItem('lang');
    if (stored === 'ru' || stored === 'en') initLang = stored;
    else if ((navigator.language || '').toLowerCase().startsWith('ru')) initLang = 'ru';
  } catch(e) {}
  applyLang(initLang);
