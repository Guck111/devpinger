# Variables prefixed with PUBLIC_ are inlined into the client bundle and
# exposed to the browser. Do not put secrets here.

# Base URL of the @devpinger/server API. Used by the email-subscribe form
# and the live "seats sold" badge.
PUBLIC_API_BASE_URL=http://localhost:3001

# Optional. When set, GoatCounter analytics is injected on every page.
# Value is your GoatCounter site code — the subdomain you picked when
# registering the site (https://<code>.goatcounter.com).
# Free tier: 100k pageviews per month, no cookies, GDPR-friendly.
# Leave unset for local development.
# PUBLIC_GOATCOUNTER_CODE=devpinger
