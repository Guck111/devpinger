# Variables prefixed with PUBLIC_ are inlined into the client bundle and
# exposed to the browser. Do not put secrets here.

# Base URL of the @devpinger/server API. Used by the email-subscribe form
# and the live "seats sold" badge.
PUBLIC_API_BASE_URL=http://localhost:3001

# Optional. When set, Plausible analytics is injected on every page.
# Leave unset for local development. In production use your registered
# Plausible domain (e.g. preorder.devpinger.com).
# PUBLIC_PLAUSIBLE_DOMAIN=preorder.devpinger.com
