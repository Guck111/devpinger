{
	"name": "@devpinger/server",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch --env-file=../../.env src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist .turbo *.tsbuildinfo"
	},
	"dependencies": {
		"@devpinger/core": "workspace:*",
		"@devpinger/crypto": "workspace:*",
		"@devpinger/db": "workspace:*",
		"@devpinger/destinations-telegram": "workspace:*",
		"@devpinger/i18n": "workspace:*",
		"@devpinger/shared": "workspace:*",
		"@devpinger/sources-github": "workspace:*",
		"@devpinger/sources-jira": "workspace:*",
		"@fastify/cors": "^10.0.1",
		"@fastify/helmet": "^12.0.1",
		"@fastify/rate-limit": "^10.2.1",
		"@sentry/node": "^9.5.0",
		"bullmq": "^5.34.5",
		"drizzle-orm": "^0.38.3",
		"fastify": "^5.2.0",
		"grammy": "^1.32.0",
		"ioredis": "^5.4.2",
		"pino": "^9.5.0",
		"pino-pretty": "^13.0.0",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@devpinger/tsconfig": "workspace:*",
		"@types/node": "^22.10.5",
		"dotenv": "^16.4.7",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	}
